---
import '@fontsource-variable/inter';
import '@fontsource-variable/manrope';
import '../styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import ClientInit from '@/components/ClientInit.astro';
import SEO from '@/components/SEO.astro';
import StructuredData from '@/components/StructuredData.astro';
import { captureUtmScript } from '@/utils/client-scripts';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  noindex?: boolean;
  ogType?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  canonical,
  noindex = false,
  ogType = 'website',
  schema,
} = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      noindex={noindex}
      ogType={ogType}
    />
    {schema && <StructuredData data={schema} />}
    <script is:inline set:html={captureUtmScript} />
  </head>
  <body>
    <a class="sr-only" href="#main">Перейти к содержимому</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <ClientInit />
  </body>
</html>
