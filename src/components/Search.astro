---
interface SearchItem {
  slug: string;
  title: string;
  shortTitle: string;
  school: string;
  author: string;
  category: string;
  categoryName: string;
  categoryDescription: string;
  subcategory: string;
  tags: string[];
  shortDescription: string;
  fullDescription: string;
  categoryAliases: string[];
  isFree: boolean;
  level: string;
  isDemo: boolean;
}

interface Props {
  /** Kept for API compatibility; client index is provided once via SearchInit. */
  searchIndex?: SearchItem[];
  variant?: 'header' | 'hero';
}

const { variant = 'header' } = Astro.props;
const inputId = variant === 'hero' ? 'hero-search' : 'header-search';
const formId = variant === 'hero' ? 'hero-search-form' : 'header-search-form';
---

<div
  class={`search search--${variant}`}
  data-search-root
  data-variant={variant}
>
  {
    variant === 'header' && (
      <button
        class="search__toggle hide-mobile"
        type="button"
        aria-label="Открыть поиск"
        data-search-open
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          aria-hidden="true"
        >
          <circle
            cx="11"
            cy="11"
            r="7"
            stroke="currentColor"
            stroke-width="1.5"
          />
          <path
            d="M20 20l-3-3"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
          />
        </svg>
      </button>
    )
  }

  <div
    class="search__panel"
    data-search-panel
    hidden={variant === 'header' ? true : undefined}
  >
    <form class="search__form" id={formId} role="search" data-search-form>
      <label class="sr-only" for={inputId}>Поиск программ</label>
      <div class="search__field">
        <svg
          class="search__icon"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.5"
          ></circle>
          <path
            d="M20 20l-3-3"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"></path>
        </svg>
        <input
          class="search__input"
          id={inputId}
          type="search"
          placeholder={variant === 'hero'
            ? 'Какому навыку вы хотите обучиться?'
            : 'Поиск программ...'}
          autocomplete="off"
          data-search-input
        />
        <button class="search__submit btn btn--primary btn--sm" type="submit">
          Найти
        </button>
      </div>
    </form>
    <div
      class="search__results"
      data-search-results
      role="listbox"
      aria-label="Результаты поиска"
      hidden
    >
    </div>
  </div>
</div>

<style>
  .search {
    position: relative;
    width: 100%;
  }
  .search__toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    padding: 0;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    cursor: pointer;
    color: var(--color-text-muted);
    transition:
      background var(--transition),
      color var(--transition);
  }
  .search__toggle:hover {
    background: var(--color-primary-soft);
    color: var(--color-primary);
  }
  .search--hero .search__panel {
    max-width: 100%;
  }
  .search--header .search__panel {
    position: absolute;
    right: 0;
    top: calc(100% + 0.5rem);
    width: min(24rem, 92vw);
    padding: var(--space-3);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    z-index: 50;
  }
  .search__form {
    margin: 0;
  }
  .search__field {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.35rem 0.35rem 0.35rem 0.85rem;
    background: var(--color-surface);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition:
      border-color var(--transition),
      box-shadow var(--transition);
  }
  .search__field:focus-within {
    border-color: var(--color-primary);
    box-shadow: var(--focus-ring);
  }
  .search__icon {
    flex-shrink: 0;
    color: var(--color-text-muted);
  }
  .search__input {
    flex: 1;
    min-width: 0;
    padding: 0.55rem 0;
    border: none;
    background: transparent;
    font: inherit;
    font-size: var(--text-sm);
    color: var(--color-text);
  }
  .search__input:focus {
    outline: none;
    box-shadow: none;
  }
  .search__input::placeholder {
    color: #94a3b8;
  }
  .search__submit {
    flex-shrink: 0;
  }
  .search--hero .search__results {
    position: relative;
    z-index: 20;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
  }
  .search__results {
    margin-top: var(--space-2);
    max-height: 16rem;
    overflow: auto;
    border-radius: var(--radius-md);
  }
  /* Dynamic results are injected without Astro scoped attrs — keep styles global. */
  .search__results :global(.search__result) {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.15rem;
    padding: 0.7rem 0.85rem;
    color: var(--color-text);
    text-decoration: none;
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    line-height: 1.35;
    border-bottom: 1px solid var(--color-border);
    transition: background var(--transition);
  }
  .search__results :global(.search__result:last-child) {
    border-bottom: none;
  }
  .search__results :global(.search__result:hover) {
    background: var(--color-primary-soft);
    text-decoration: none;
  }
  .search__results :global(.search__result strong),
  .search__results :global(.search__result-title) {
    display: block;
    font-weight: 600;
    color: var(--color-text);
  }
  .search__results :global(.search__result span),
  .search__results :global(.search__result-meta) {
    display: block;
    color: var(--color-text-muted);
    font-size: var(--text-xs);
  }
  .search__results :global(.search__empty) {
    margin: 0;
    padding: var(--space-3);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }
</style>
