---
interface Props {
  courseId: string;
  courseSlug: string;
  courseTitle: string;
  compact?: boolean;
}

const { courseId, courseSlug, courseTitle, compact = false } = Astro.props;
---

<button
  class:list={['compare-btn', { 'compare-btn--compact': compact }]}
  type="button"
  aria-label="Добавить к сравнению"
  data-compare-btn
  data-course-id={courseId}
  data-course-slug={courseSlug}
  data-course-title={courseTitle}
>
  {
    compact ? (
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
        />
      </svg>
    ) : (
      'Сравнить'
    )
  }
</button>

<style>
  .compare-btn {
    padding: 0.35rem 0.6rem;
    font-size: var(--text-xs);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    cursor: pointer;
    color: var(--color-text-muted);
    transition: all var(--transition);
  }
  .compare-btn--compact {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.3rem;
    background: transparent;
    border-color: transparent;
  }
  .compare-btn--compact:hover {
    background: var(--color-primary-soft);
    color: var(--color-primary);
  }
  .compare-btn.is-active,
  .compare-btn--compact.is-active {
    color: var(--color-primary);
    border-color: var(--color-primary-muted);
    background: var(--color-primary-soft);
  }
</style>
