---
import { getCategoryById } from '@/config/categories';

interface Props {
  categoryId: string;
  class?: string;
}

const { categoryId, class: className = '' } = Astro.props;
const category = getCategoryById(categoryId);
const theme = category?.theme ?? 'theme-ai';
---

<div class={`course-placeholder ${theme} ${className}`} aria-hidden="true">
  <svg
    viewBox="0 0 400 225"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    preserveAspectRatio="xMidYMid slice"
  >
    <rect width="400" height="225" fill="url(#bg)"></rect>
    <defs>
      <linearGradient
        id="bg"
        x1="0"
        y1="0"
        x2="400"
        y2="225"
        gradientUnits="userSpaceOnUse"
      >
        <stop stop-color="var(--cat-soft)"></stop>
        <stop offset="1" stop-color="white"></stop>
      </linearGradient>
    </defs>
    <circle cx="320" cy="40" r="60" fill="var(--cat-accent)" opacity="0.08"
    ></circle>
    <circle cx="60" cy="180" r="45" fill="var(--cat-accent)" opacity="0.06"
    ></circle>
    {
      categoryId === 'neyroseti' && (
        <>
          <circle
            cx="200"
            cy="112"
            r="28"
            stroke="var(--cat-accent)"
            stroke-width="2"
            opacity="0.5"
          />
          <circle
            cx="155"
            cy="90"
            r="8"
            fill="var(--cat-accent)"
            opacity="0.35"
          />
          <circle
            cx="245"
            cy="90"
            r="8"
            fill="var(--cat-accent)"
            opacity="0.35"
          />
          <circle
            cx="200"
            cy="155"
            r="8"
            fill="var(--cat-accent)"
            opacity="0.35"
          />
          <path
            d="M163 98h30M237 98h-30M185 130l15 18M215 130l-15 18"
            stroke="var(--cat-accent)"
            stroke-width="1.5"
            opacity="0.4"
          />
        </>
      )
    }
    {
      categoryId === 'marketing' && (
        <>
          <rect
            x="150"
            y="130"
            width="100"
            height="60"
            rx="4"
            fill="var(--cat-accent)"
            opacity="0.15"
          />
          <path
            d="M160 170l20-30 15 20 25-35 20 45"
            stroke="var(--cat-accent)"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            opacity="0.5"
          />
          <circle
            cx="200"
            cy="75"
            r="20"
            stroke="var(--cat-accent)"
            stroke-width="2"
            opacity="0.4"
          />
        </>
      )
    }
    {
      categoryId === 'psihologiya' && (
        <>
          <ellipse
            cx="175"
            cy="115"
            rx="22"
            ry="28"
            stroke="var(--cat-accent)"
            stroke-width="2"
            opacity="0.45"
          />
          <ellipse
            cx="225"
            cy="115"
            rx="22"
            ry="28"
            stroke="var(--cat-accent)"
            stroke-width="2"
            opacity="0.45"
          />
          <path
            d="M195 115c0 8 5 14 5 20M205 115c0 8-5 14-5 20"
            stroke="var(--cat-accent)"
            stroke-width="1.5"
            opacity="0.35"
          />
        </>
      )
    }
    {
      categoryId === 'zdorove' && (
        <>
          <path
            d="M200 70c-15 20-35 25-35 45 0 15 12 25 35 40 23-15 35-25 35-40 0-20-20-25-35-45z"
            stroke="var(--cat-accent)"
            stroke-width="2"
            opacity="0.45"
            fill="var(--cat-accent)"
            fill-opacity="0.08"
          />
          <path
            d="M185 105h30M200 90v30"
            stroke="var(--cat-accent)"
            stroke-width="2"
            opacity="0.4"
            stroke-linecap="round"
          />
        </>
      )
    }
    {
      categoryId === 'dizayn' && (
        <>
          <rect
            x="140"
            y="80"
            width="120"
            height="80"
            rx="6"
            stroke="var(--cat-accent)"
            stroke-width="2"
            opacity="0.4"
          />
          <circle
            cx="165"
            cy="105"
            r="10"
            fill="var(--cat-accent)"
            opacity="0.25"
          />
          <path
            d="M150 145l30-25 20 15 30-30"
            stroke="var(--cat-accent)"
            stroke-width="2"
            opacity="0.45"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </>
      )
    }
    {
      categoryId === 'angliyskiy' && (
        <>
          <circle
            cx="200"
            cy="112"
            r="45"
            stroke="var(--cat-accent)"
            stroke-width="2"
            opacity="0.4"
          />
          <ellipse
            cx="200"
            cy="112"
            rx="45"
            ry="18"
            stroke="var(--cat-accent)"
            stroke-width="1.5"
            opacity="0.3"
          />
          <path
            d="M155 112h90"
            stroke="var(--cat-accent)"
            stroke-width="1.5"
            opacity="0.3"
          />
          <rect
            x="170"
            y="155"
            width="60"
            height="24"
            rx="12"
            fill="var(--cat-accent)"
            opacity="0.12"
          />
          <rect
            x="185"
            y="163"
            width="30"
            height="8"
            rx="4"
            fill="var(--cat-accent)"
            opacity="0.25"
          />
        </>
      )
    }
  </svg>
</div>

<style>
  .course-placeholder {
    width: 100%;
    height: 100%;
    background: var(--cat-soft);
  }
  .course-placeholder svg {
    width: 100%;
    height: 100%;
  }
</style>
