---
interface Props {
  variant?: 'free' | 'paid' | 'trial' | 'demo' | 'soon' | 'default';
}

const { variant = 'default' } = Astro.props;
const classMap = {
  free: 'badge badge--free',
  paid: 'badge badge--paid',
  trial: 'badge badge--trial',
  demo: 'badge badge--demo',
  soon: 'badge badge--soon',
  default: 'badge',
};
---

<span class={classMap[variant]}><slot /></span>
